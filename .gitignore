# Credentials — never commit real keys
.env
.env.local

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Working/scratch outputs — noncanonical, regenerable, or relay-bundle staging.
# Durable artifacts (evidence layer, ledger, audit docs) belong in docs/analysis/,
# not here. See docs/analysis/repo_cleanup_audit_2026-07-14.md for the retention
# policy this formalizes.
tmp/

# Corpus full-text storage — UNCOMMENT to keep documents out of git (Option A).
# Licensed Westlaw/Lexis/Factiva pulls should NOT be committed to a shared remote.
# corpus/

# Keep the corpus/ folder tracked even if empty
!corpus/.gitkeep
