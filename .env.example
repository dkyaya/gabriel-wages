# Harvard HUIT OpenAI proxy credentials.
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
#
# The subscription key is used as both the api_key slot and the
# Ocp-Apim-Subscription-Key header (standard HUIT auth pattern).
# No separate OpenAI key is needed.

export HARVARD_SUBSCRIPTION_KEY=your-harvard-subscription-key
